<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Palet "Sticky Note" — nuansa kuning hangat khas kertas memo -->
    <color name="note_primary">#F9A825</color>        <!-- kuning amber: aksen utama & FAB -->
    <color name="note_on_primary">#3E2723</color>      <!-- cokelat tua: teks di atas primary -->
    <color name="note_surface">#FFFDE7</color>         <!-- krem sangat muda: latar kartu -->
    <color name="note_on_surface">#4E342E</color>      <!-- cokelat: teks utama -->
    <color name="note_background">#FFF8E1</color>      <!-- latar layar -->
    <color name="note_secondary_container">#FFF176</color> <!-- kuning muda: kartu catatan -->
    <color name="note_on_secondary_container">#33691E</color>

    <!-- Palet warna kartu catatan — dipilih bebas oleh user per catatan, ala sticky note fisik -->
    <color name="note_card_yellow">#FFF9C4</color>
    <color name="note_card_pink">#F8BBD0</color>
    <color name="note_card_blue">#B3E5FC</color>
    <color name="note_card_green">#C8E6C9</color>
    <color name="note_card_purple">#E1BEE7</color>
    <color name="note_card_orange">#FFCCBC</color>
</resources>